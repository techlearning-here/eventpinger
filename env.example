# Eventpinger — environment variables (reference)
# Feature ↔ env mapping: docs/FEATURES.md §5
# Copy the sections you need into:
#   frontend/.env.local   (from frontend/.env.example)
#   backend/.env          (from backend/.env.example)
# Never commit real secrets.

# =============================================================================
# FRONTEND (Next.js) — prefix NEXT_PUBLIC_* is exposed to the browser
# =============================================================================
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# =============================================================================
# BACKEND (FastAPI) — server-only; do not expose service role to the client
# =============================================================================
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# O7 Eventbrite import (server-only): docs/eventbrite_api_testing.md
# EVENTBRITE_PRIVATE_TOKEN=your_private_token

# =============================================================================
# SUPABASE CLI (local) — run `npx supabase status` after `npx supabase start`
# =============================================================================
# Use printed API URL, anon key, and service_role for backend/frontend above.
# Optional: SUPABASE_ACCESS_TOKEN for `supabase link` (CI / scripts).
