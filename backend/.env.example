# Env ↔ features: ../docs/FEATURES.md §5
# Copy to backend/.env and load before uvicorn, e.g.:
#   set -a && source .env && set +a && uvicorn app.main:app --reload --port 8000
# Or use a process manager / hosting env UI (never commit .env).

# Required for live reads from Supabase (otherwise /v1/events returns []).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Optional — Eventbrite API (O7 import exploration). Not read by the API app until wired.
# EVENTBRITE_PRIVATE_TOKEN=your_private_token
